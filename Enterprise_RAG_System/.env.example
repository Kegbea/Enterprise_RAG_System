# ==================== DashScope API ====================
# 通义千问大模型 + 向量模型 API
# 获取地址: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=sk-ws-H.REYXLLI.o61Y.MEYCIQD--SasTQU_DaMmVKojM5TqlDNStlBYPq1IhX7hfgdbVgIhAOHAbacmi05s2kzk0AYKJLPRsTOtrjX45ByqG3_XQVKv

# ── 模型选型 ──
# LLM: qwen-plus / qwen-turbo / qwen-max
LLM_MODEL=qwen-plus
# Embedding: text-embedding-v3 / text-embedding-v2
EMBEDDING_MODEL=text-embedding-v3

# ==================== 向量数据库 ====================
# ChromaDB 本地持久化路径（相对项目根目录）
CHROMA_PERSIST_DIR=data/chroma
# ChromaDB 集合名称
CHROMA_COLLECTION_NAME=enterprise_knowledge

# ==================== 重排序模型 ====================
# bge-reranker 模型路径（支持 HuggingFace ID 或本地绝对路径）
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# 若已下载到本地，可设为: /path/to/bge-reranker-v2-m3

# ==================== 文档存储 ====================
# 上传文件归档目录
DOCUMENT_ARCHIVE_DIR=data/documents

# ==================== 对话历史 ====================
# 会话数据持久化目录
SESSION_DIR=data/sessions

# ==================== 应用配置 ====================
# 切块大小 (tokens)
CHUNK_SIZE=512
# 切块重叠 (tokens)
CHUNK_OVERLAP=50
# 检索返回候选数
TOP_K=5
# 混合检索候选数（重排序前）
HYBRID_TOP_K=15

# ==================== 服务配置 ====================
# FastAPI 服务 host/port
API_HOST=0.0.0.0
API_PORT=8000
# Streamlit 服务端口
UI_PORT=8501
